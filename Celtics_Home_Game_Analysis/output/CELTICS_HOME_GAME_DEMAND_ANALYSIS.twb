      <aliases enabled='yes' />
      <column caption='IS_WEEKEND' datatype='integer' name='[Calculation_725361069861240833]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [DAY_OF_WEEK] = &quot;Saturday&quot; OR [DAY_OF_WEEK] = &quot;Sunday&quot; &#13;&#10;THEN 3 &#13;&#10;ELSE 0 &#13;&#10;END' />
      </column>
      <column caption='IS_PRIME_TIME' datatype='integer' name='[Calculation_725361069861449730]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF TIME &gt;= &quot;19:00&quot; AND TIME &lt;= &quot;20:00&quot; //7PM - 8PM&#13;&#10;THEN 1 &#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='IS_NBA_CUP' datatype='integer' name='[Calculation_725361069862199299]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [NBA_CUP] = &quot;NBA CUP&quot;&#13;&#10;THEN 3&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='IS_PRIME_MONTH' datatype='integer' name='[Calculation_725361069863809028]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [MONTH] IN (12,3,4) &#13;&#10;THEN 1 &#13;&#10;ELSE 0 &#13;&#10;END' />
      </column>
      <column caption='OPPONENT TIER' datatype='integer' name='[Calculation_725361069864984581]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [OPPONENT] IN &#13;&#10;    (&quot;Los Angeles Lakers&quot;)&#13;&#10;Then 6&#13;&#10;&#13;&#10;&#13;&#10;ELSEIF  [OPPONENT] IN &#13;&#10;    ( &quot;Golden State Warriors&quot;, &quot;New York Knicks&quot;) &#13;&#10;THEN 5&#13;&#10;&#13;&#10;ELSEIF [OPPONENT] IN &#13;&#10;    (&quot;Philadelphia 76ers&quot;, &quot;Denver Nuggets&quot;, &quot;San Antonio Spurs&quot;,&quot;Dallas Mavericks&quot; ) &#13;&#10;THEN 4&#13;&#10;&#13;&#10;ELSEIF [OPPONENT] IN &#13;&#10;    (&quot;Brooklyn Nets&quot;, &quot;Houston Rockets&quot;, &#13;&#10;    &quot;Miami Heat&quot;, &quot;Milwaukee Bucks&quot;, &quot;Detroit Pistons&quot;) &#13;&#10;THEN 2&#13;&#10;&#13;&#10;ELSE 0 &#13;&#10;END' />
      </column>
      <column caption='game_attractiveness_score' datatype='integer' name='[Calculation_725361069867610118]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_725361069861240833] + [Calculation_725361069863809028] + [Calculation_725361069861449730] &#13;&#10;&#13;&#10;+ [Calculation_725361069862199299] + [Calculation_725361069864984581]' />
      </column>
      <column caption='% Weekend' datatype='real' name='[Calculation_725361069885247504]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_725361069861240833]) / COUNT([GAME_NUM])' />
      </column>
      <column caption='HIGH DEMAND GAMES' datatype='real' name='[Calculation_725361069890428946]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Calculation_725361069867610118] &gt;= 3 THEN 1 ELSE 0 END)&#13;&#10;/ COUNTD([GAME_NUM])' />
      </column>
      <column caption='Day Of Week' datatype='string' name='[DAY_OF_WEEK]' role='dimension' type='nominal' />
      <column caption='Game Num' datatype='string' name='[GAME_NUM]' role='dimension' type='nominal' />
      <column aggregation='Sum' caption='Month' datatype='integer' name='[MONTH]' role='dimension' type='ordinal' />
      <column caption='Nba Cup' datatype='string' name='[NBA_CUP]' role='dimension' type='nominal' />
      <column caption='Opponent' datatype='string' name='[OPPONENT]' role='dimension' type='nominal' />
      <column caption='Time' datatype='string' name='[TIME]' role='dimension' type='nominal' />
      <column caption='Win Streak' datatype='string' name='[WIN_STREAK]' role='dimension' type='nominal' />
      <column caption='Year' datatype='integer' name='[YEAR]' role='dimension' type='quantitative' />
